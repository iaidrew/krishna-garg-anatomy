rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (Zero-Trust Catch-All)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Helper to identify verified administrators
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.toLowerCase() == "adityaofficial9918@gmail.com" ||
        (exists(/databases/$(database)/documents/config/admins) && request.auth.token.email.toLowerCase() in get(/databases/$(database)/documents/config/admins).data.emails) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin")
      );
    }

    // --- COLLECTION MATCHES ---

    // 1. Courses Collection
    match /courses/{courseId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidId(courseId);
    }

    // 2. Scholar Profiles (Users)
    match /users/{userId} {
      // Admins can view all scholar profiles. Users can read their own profile.
      allow read: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      
      // Allow profile deletion only for administrators
      allow delete: if isAdmin();

      // Creation rules with self-assignment protection
      allow create: if isSignedIn() && userId == request.auth.uid && isValidId(userId) && isValidUser(incoming()) && (
        incoming().role == "student" ||
        incoming().role == "admin" && (
          request.auth.token.email.toLowerCase() == "adityaofficial9918@gmail.com" ||
          (exists(/databases/$(database)/documents/config/admins) && request.auth.token.email.toLowerCase() in get(/databases/$(database)/documents/config/admins).data.emails) ||
          (incoming().registrationPasscode is string && incoming().registrationPasscode == get(/databases/$(database)/documents/config/settings).data.adminPasscode)
        )
      );

      // Update rules with action-based privilege separation
      allow update: if isSignedIn() && (
        isAdmin() ||
        (userId == request.auth.uid && isValidUser(incoming()) && (
          // Protect immortal fields (uid, email, createdAt)
          incoming().uid == existing().uid &&
          incoming().email == existing().email &&
          
          // Users cannot escalate their own privilege unless they satisfy the passcode verification
          (
            incoming().role == existing().role ||
            (incoming().role == "admin" && (
              request.auth.token.email.toLowerCase() == "adityaofficial9918@gmail.com" ||
              (exists(/databases/$(database)/documents/config/admins) && request.auth.token.email.toLowerCase() in get(/databases/$(database)/documents/config/admins).data.emails) ||
              (incoming().registrationPasscode is string && incoming().registrationPasscode == get(/databases/$(database)/documents/config/settings).data.adminPasscode)
            ))
          )
        ))
      );
    }

    // Validation helper for Scholar profiles
    function isValidUser(user) {
      return user.uid is string && user.uid.size() <= 128 &&
             user.name is string && user.name.size() <= 120 &&
             user.email is string && user.email.size() <= 120 &&
             user.role is string && (user.role == "student" || user.role == "admin");
    }

    // 3. Student Contact Inquiries (PII Isolation Enforced)
    match /contacts/{contactId} {
      // Anyone can submit an inquiry (leads, guests, or scholars)
      allow create: if isValidId(contactId) && isValidContact(incoming());
      
      // Reading, updating read-status, or deleting inquiries is strictly locked to administrators.
      // This enforces complete PII Isolation for names, emails, and mobile numbers.
      allow read, update, delete: if isAdmin();
    }

    // Validation helper for Student inquiries
    function isValidContact(contact) {
      return contact.id is string && contact.id.size() <= 128 &&
             contact.name is string && contact.name.size() <= 120 &&
             contact.email is string && contact.email.size() <= 120 &&
             contact.mobile is string && contact.mobile.size() <= 40 &&
             contact.message is string && contact.message.size() <= 5000 &&
             contact.timestamp is string && contact.timestamp.size() <= 100;
    }

    // 4. System Configurations (Admins and Settings)
    match /config/{docId} {
      // Config documents are readable publicly to permit validation checks
      allow read: if true;
      
      // Updates are locked down exclusively to administrators
      allow create, update, delete: if isAdmin() && isValidId(docId);
    }

    // 5. Cloud-Backed Files Storage (Durable file index for ephemeral container storage)
    match /files/{filename} {
      allow read: if true;
      allow create, update: if (incoming().secret == "GARG_SERVER_SECRET_2026") || isAdmin();
      allow delete: if isAdmin();

      match /chunks/{chunkId} {
        allow read: if true;
        allow create, update: if (incoming().secret == "GARG_SERVER_SECRET_2026") || isAdmin();
        allow delete: if isAdmin();
      }
    }
  }
}
